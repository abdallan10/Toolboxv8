# ============================================================
# ToolboxV8 – Configuration
# Copier ce fichier en .env et adapter les valeurs.
# Les clés SECRET_KEY et FERNET_KEY sont générées automatiquement
# par scripts/start.sh ou scripts/start.ps1 au premier démarrage.
# ============================================================

# ---- Application ----
APP_NAME=ToolboxV8
DEBUG=false

# IMPORTANT : générer avec : openssl rand -hex 32
SECRET_KEY=changeme-in-production-use-openssl-rand-hex-32

# Durée du token JWT (en minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Hosts autorisés ----
# 'caddy' inclus car le reverse proxy HTTPS forward avec ce Host en interne
ALLOWED_HOSTS=["localhost","127.0.0.1","api","api:8000","caddy","web"]
ALLOWED_ORIGINS=["https://localhost","http://localhost","http://localhost:8000","http://localhost:3000"]

# ---- Base de données PostgreSQL ----
DATABASE_URL=postgresql://pentest:pentest@db:5432/pentestdb

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- MinIO (stockage des rapports) ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pentest-reports
MINIO_SECURE=false

# ---- Chiffrement Fernet ----
# Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=changeme-generate-with-fernet

# ---- APIs externes (optionnel) ----
VIRUSTOTAL_API_KEY=

# ---- ELK / Elasticsearch ----
ELASTICSEARCH_URL=http://elasticsearch:9200

# ---- OWASP ZAP (module web_scan) ----
# Service zap defini dans docker-compose.yml, daemon API sur :8080
ZAP_URL=http://zap:8080
ZAP_API_KEY=zapsecret

# ---- Compte admin auto (créé au démarrage par scripts/start.sh|ps1) ----
# Modifier impérativement en production. Si laissés vides, les valeurs ci-dessous
# sont utilisées par défaut.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@pentestbox.com
